rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: games
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, 1-100 chars)
    //   - description: string (optional, 0-500 chars)
    //   - thumbnailUrl: string (optional, valid URL)
    //   - gameUrl: string (required, valid URL)
    //   - category: string (required, must be in CATEGORIES)
    //   - addedAt: number (required, timestamp)
    //   - type: string (required, 'url' or 'html')
    //   - htmlContent: string (optional, if type is 'html')
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "salvonick3@gmail.com" && request.auth.token.email_verified == true) ||
          request.auth.token.firebase.sign_in_provider == 'anonymous'); // Allow anonymous auth for the password-based admin portal
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidGame(data) {
      let categories = ['Action', 'Puzzle', 'Sports', 'Strategy', 'Retro', 'Other'];
      return data.keys().hasAll(['title', 'category', 'addedAt', 'type']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 500)) &&
             (!('thumbnailUrl' in data) || (data.thumbnailUrl == "" || isValidUrl(data.thumbnailUrl))) &&
             (!('gameUrl' in data) || (data.gameUrl == "" || isValidUrl(data.gameUrl))) &&
             data.category in categories &&
             data.addedAt is number &&
             data.type in ['url', 'html'] &&
             (!('htmlContent' in data) || (data.htmlContent is string && data.htmlContent.size() <= 1048576)); // 1MB limit
    }

    // Games collection rules
    match /games/{gameId} {
      // Anyone can read games
      allow read: if true;
      
      // Only admins can modify games
      allow create, update: if isAdmin() && isValidGame(request.resource.data);
      allow delete: if isAdmin();
    }

    // Users collection rules (for RBAC)
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create, update: if isAdmin(); // Only admins can manage roles
    }
  }
}
